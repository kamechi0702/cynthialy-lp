---
/**
 * /services/wazatsugu — 暗黙知継承サービス「わざツグ」紹介ページ
 * ----------------------------------------------------------------
 * docs/Design.md のセクションアーキタイプに従って新規にコンポーネント実装。
 * cynthialy.co.jp に存在しないプロダクトページのため、ミラー注入は使わない。
 *
 * セクション構成（10）:
 *   1. Hero
 *   2. The Problem (3カード)
 *   3. Three Purposes (3カード・SVGアイコン)
 *   4. Approach (5ステップ縦タイムライン)
 *   5. Tech Card Showcase (5観点・SVGアイコン)
 *   6. Use Cases (2カード)
 *   7. Voices (大数字 + 引用4枚)
 *   8. Session Timeline (横タイムライン)
 *   9. Plans (3プラン比較)
 *   10. CTA Block (cynthialy 標準)
 */

const pageTitle =
  "わざツグ｜暗黙知継承サービス｜技を、つなぐ | シンシアリー株式会社";
const pageDescription =
  "ベテランの「なんとなく」を生成AIとの対話で形式知化し、再利用可能な「技カード」として組織の資産に変える暗黙知継承サービス。育成・標準化・AI化に活用可能。";
const canonical = "https://cynthialy.co.jp/services/wazatsugu/";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="all" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Inter:wght@400;500;700&family=Lato:wght@700&display=swap"
      rel="stylesheet"
    />

    <style>
      /* =============================================================
       * Design tokens (subset of cto/design-tokens/tokens.css)
       * 詳細は docs/Design.md §2 参照
       * ============================================================= */
      :root {
        --color-deep-green: #0d2623;
        --color-accent-gold: #e8de9f;
        --color-accent-gold-light: #f9f9ba;
        --color-accent-gold-dark: #e6dfa2;
        --color-white: #ffffff;
        --color-neutral-100-txt: #030807;
        --color-neutral-80-txt: #384946;
        --color-neutral-60-border: #7b8180;
        --color-neutral-30-border: #dbdbdb;
        --color-neutral-10-bg: #f1f1f1;
        --surface-card: #ffffffd4;
        --surface-lightgreen-bg: rgba(237, 242, 231, 0.8);
        --color-link: #4584ae;

        --gradient-hero: linear-gradient(
          90deg,
          #0d2623e6 51%,
          #e8de9fe6 87%,
          rgba(142, 205, 168, 0.9) 94%,
          rgba(65, 190, 175, 0.9)
        );
        --gradient-soft: linear-gradient(
          135deg,
          rgba(232, 222, 159, 0.18) 0%,
          rgba(13, 38, 35, 0.04) 60%,
          rgba(232, 222, 159, 0.12) 100%
        );
        --gradient-gold: linear-gradient(90deg, #f9f9ba, #e6dfa2);

        --font-sans-jp: "Noto Sans JP", "Hiragino Kaku Gothic ProN", sans-serif;
        --font-sans-en: "Inter", "Lato", system-ui, sans-serif;

        --letter-spacing-tight: -0.02em;
        --letter-spacing-wider: 0.1em;

        --space-1: 4px;
        --space-2: 8px;
        --space-3: 12px;
        --space-4: 16px;
        --space-5: 20px;
        --space-6: 24px;
        --space-8: 32px;
        --space-10: 40px;
        --space-12: 48px;
        --space-16: 64px;
        --space-20: 80px;
        --space-24: 96px;
        --space-32: 128px;

        --radius-sm: 4px;
        --radius-md: 8px;
        --radius-lg: 16px;
        --radius-xl: 24px;
        --radius-pill: 9999px;

        --shadow-sm: 0 1px 2px rgba(13, 38, 35, 0.08);
        --shadow-md: 0 4px 12px rgba(13, 38, 35, 0.1);
        --shadow-lg: 0 12px 32px rgba(13, 38, 35, 0.14);

        --duration-base: 300ms;
        --ease-out: cubic-bezier(0.2, 0, 0, 1);

        /* 派生：深緑のソフトトーン（背景帯・アクセント用） */
        --color-deep-green-08: rgba(13, 38, 35, 0.08);
        --color-deep-green-12: rgba(13, 38, 35, 0.12);
        --color-deep-green-soft: #f4f7f6;
      }

      /* ===== Reset ===== */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html {
        -webkit-font-smoothing: antialiased;
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        font-family: var(--font-sans-jp);
        font-size: 16px;
        line-height: 1.6;
        color: var(--color-neutral-100-txt);
        background: var(--color-white);
      }
      a {
        color: inherit;
        text-decoration: none;
      }
      img,
      svg {
        display: block;
        max-width: 100%;
      }
      h1,
      h2,
      h3,
      h4,
      p,
      ul {
        margin: 0;
      }
      ul {
        padding: 0;
        list-style: none;
      }
      button {
        font-family: inherit;
      }

      /* ===== Header ===== */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 300;
        background: rgba(255, 255, 255, 0.94);
        backdrop-filter: saturate(140%) blur(10px);
        -webkit-backdrop-filter: saturate(140%) blur(10px);
        border-bottom: 1px solid var(--color-neutral-30-border);
      }
      .site-header__inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: var(--space-4) var(--space-6);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-6);
      }
      .site-header__brand {
        display: flex;
        align-items: baseline;
        gap: var(--space-3);
        font-family: var(--font-sans-en);
        color: var(--color-deep-green);
      }
      .site-header__brand-name {
        font-size: 18px;
        font-weight: 700;
        letter-spacing: var(--letter-spacing-wider);
      }
      .site-header__brand-divider {
        width: 1px;
        height: 16px;
        background: var(--color-neutral-30-border);
      }
      .site-header__brand-product {
        font-family: var(--font-sans-jp);
        font-size: 14px;
        font-weight: 700;
      }
      .site-header__nav {
        display: flex;
        gap: var(--space-6);
        font-size: 14px;
      }
      .site-header__nav a {
        color: var(--color-neutral-80-txt);
        transition: color var(--duration-base) var(--ease-out);
      }
      .site-header__nav a:hover {
        color: var(--color-deep-green);
      }
      .site-header__cta {
        background: var(--color-deep-green);
        color: var(--color-white);
        padding: 8px 16px;
        border-radius: var(--radius-md);
        font-size: 13px;
        font-weight: 700;
        transition: transform var(--duration-base) var(--ease-out),
          box-shadow var(--duration-base) var(--ease-out);
      }
      .site-header__cta:hover {
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
      }
      @media (max-width: 720px) {
        .site-header__nav {
          display: none;
        }
      }

      /* ===== Common section primitives ===== */
      .section {
        padding: var(--space-24) var(--space-6);
      }
      .section__inner {
        max-width: 1180px;
        margin: 0 auto;
      }
      .section__eyebrow {
        font-family: var(--font-sans-en);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: var(--letter-spacing-wider);
        color: var(--color-deep-green);
        margin-bottom: var(--space-4);
        display: inline-block;
        padding-bottom: var(--space-2);
        border-bottom: 2px solid var(--color-accent-gold);
      }
      .section__title {
        font-size: clamp(28px, 4vw, 44px);
        font-weight: 700;
        line-height: 1.25;
        margin-bottom: var(--space-6);
        color: var(--color-deep-green);
        letter-spacing: var(--letter-spacing-tight);
      }
      .section__lead {
        font-size: 18px;
        line-height: 1.8;
        color: var(--color-neutral-80-txt);
        max-width: 780px;
        margin-bottom: var(--space-12);
      }
      @media (max-width: 720px) {
        .section {
          padding: var(--space-16) var(--space-6);
        }
        .section__lead {
          font-size: 16px;
          margin-bottom: var(--space-8);
        }
      }

      /* ===== Buttons ===== */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        padding: 14px 28px;
        border-radius: var(--radius-md);
        font-family: inherit;
        font-weight: 700;
        font-size: 15px;
        cursor: pointer;
        border: 0;
        text-align: center;
        transition: transform var(--duration-base) var(--ease-out),
          box-shadow var(--duration-base) var(--ease-out),
          background-color var(--duration-base) var(--ease-out),
          color var(--duration-base) var(--ease-out);
      }
      .btn--primary {
        background: var(--color-deep-green);
        color: var(--color-white);
      }
      .btn--primary:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
      }
      .btn--secondary {
        background: var(--color-white);
        color: var(--color-deep-green);
        border: 1.5px solid var(--color-deep-green);
      }
      .btn--secondary:hover {
        background: var(--color-deep-green);
        color: var(--color-white);
      }
      .btn__arrow {
        width: 14px;
        height: 14px;
        stroke: currentColor;
        stroke-width: 2;
        fill: none;
      }

      /* ===== HERO ===== */
      .hero {
        position: relative;
        padding: var(--space-32) var(--space-6) var(--space-24);
        background:
          radial-gradient(
            ellipse at top right,
            rgba(232, 222, 159, 0.32) 0%,
            transparent 55%
          ),
          radial-gradient(
            ellipse 60% 80% at bottom left,
            rgba(13, 38, 35, 0.10) 0%,
            transparent 60%
          ),
          var(--color-white);
        overflow: hidden;
      }
      .hero::before {
        /* 左端の深緑アクセントバー */
        content: "";
        position: absolute;
        left: 0;
        top: 12%;
        bottom: 12%;
        width: 6px;
        background: var(--color-deep-green);
        border-radius: 0 var(--radius-md) var(--radius-md) 0;
      }
      .hero__photo-backdrop {
        position: absolute;
        right: -120px;
        bottom: -80px;
        width: 520px;
        height: 360px;
        opacity: 0.55;
        z-index: 0;
        transform: rotate(-2deg);
      }
      @media (max-width: 880px) {
        .hero__photo-backdrop {
          display: none;
        }
      }
      .hero__inner { position: relative; z-index: 1; }
      .hero__inner {
        max-width: 1280px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        gap: var(--space-16);
        align-items: center;
      }
      .hero__title-en {
        display: block;
        font-family: var(--font-sans-en);
        font-size: 14px;
        font-weight: 700;
        letter-spacing: var(--letter-spacing-wider);
        color: var(--color-deep-green);
        margin-bottom: var(--space-4);
      }
      .hero__title {
        font-size: clamp(40px, 6vw, 68px);
        font-weight: 700;
        line-height: 1.1;
        color: var(--color-deep-green);
        margin-bottom: var(--space-6);
        letter-spacing: var(--letter-spacing-tight);
      }
      .hero__title em {
        font-style: normal;
        background: var(--gradient-gold);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
      }
      .hero__lead {
        font-size: 19px;
        line-height: 1.7;
        color: var(--color-neutral-80-txt);
        margin-bottom: var(--space-12);
        max-width: 540px;
      }
      .hero__stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-3);
        margin-bottom: var(--space-12);
        max-width: 540px;
      }
      .stat-badge {
        text-align: center;
        padding: var(--space-4) var(--space-3);
        background: var(--surface-card);
        border: 1px solid var(--color-neutral-30-border);
        border-radius: var(--radius-md);
      }
      .stat-badge__value {
        display: block;
        font-family: var(--font-sans-en);
        font-size: 28px;
        font-weight: 700;
        color: var(--color-deep-green);
        line-height: 1;
      }
      .stat-badge__label {
        display: block;
        font-size: 11px;
        color: var(--color-neutral-80-txt);
        margin-top: var(--space-2);
        line-height: 1.4;
      }
      .hero__ctas {
        display: flex;
        gap: var(--space-4);
        flex-wrap: wrap;
      }
      /* Hero visual: stylized tech card */
      .hero__visual {
        position: relative;
        aspect-ratio: 1 / 1;
        background:
          radial-gradient(
            circle at 30% 30%,
            rgba(232, 222, 159, 0.4),
            rgba(232, 222, 159, 0) 60%
          ),
          var(--gradient-soft);
        border-radius: var(--radius-xl);
        padding: var(--space-12);
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .hero__visual-card {
        width: 100%;
        max-width: 360px;
        background: var(--color-white);
        border-radius: var(--radius-lg);
        padding: var(--space-6);
        box-shadow: var(--shadow-lg);
        transform: rotate(-2.5deg);
        font-size: 13px;
        line-height: 1.6;
      }
      .hero__visual-card-no {
        font-family: var(--font-sans-en);
        font-size: 11px;
        letter-spacing: var(--letter-spacing-wider);
        color: var(--color-deep-green);
        opacity: 0.6;
        margin-bottom: var(--space-2);
      }
      .hero__visual-card-title {
        font-size: 17px;
        font-weight: 700;
        color: var(--color-deep-green);
        margin-bottom: var(--space-4);
        line-height: 1.4;
      }
      .hero__visual-card-row {
        display: grid;
        grid-template-columns: 24px 1fr;
        gap: var(--space-3);
        align-items: flex-start;
        padding: var(--space-2) 0;
        border-top: 1px solid var(--color-neutral-30-border);
      }
      .hero__visual-card-row:first-of-type {
        border-top: 0;
      }
      .hero__visual-card-row svg {
        width: 20px;
        height: 20px;
        color: var(--color-deep-green);
      }
      .hero__visual-card-row span {
        color: var(--color-neutral-80-txt);
        font-size: 12px;
      }
      @media (max-width: 880px) {
        .hero {
          padding: var(--space-20) var(--space-6) var(--space-16);
        }
        .hero__inner {
          grid-template-columns: 1fr;
          gap: var(--space-12);
        }
        .hero__visual {
          max-width: 420px;
          margin: 0 auto;
        }
      }
      @media (max-width: 540px) {
        .hero__stats {
          grid-template-columns: 1fr;
          max-width: 100%;
        }
        .hero__ctas .btn {
          width: 100%;
          justify-content: center;
        }
      }

      /* ===== Cards generic ===== */
      .cards-grid {
        display: grid;
        gap: var(--space-6);
      }
      .cards-grid--3 {
        grid-template-columns: repeat(3, 1fr);
      }
      .cards-grid--2 {
        grid-template-columns: repeat(2, 1fr);
      }
      @media (max-width: 1080px) {
        .cards-grid--3 {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      @media (max-width: 720px) {
        .cards-grid--3,
        .cards-grid--2 {
          grid-template-columns: 1fr;
        }
      }

      /* ===== Problem section ===== */
      .problem {
        background: var(--color-neutral-10-bg);
      }
      .issue-card {
        position: relative;
        background: var(--color-white);
        border-radius: var(--radius-lg);
        padding: var(--space-8);
        padding-top: calc(var(--space-8) + 4px);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--color-neutral-30-border);
        transition: transform var(--duration-base) var(--ease-out),
          box-shadow var(--duration-base) var(--ease-out);
      }
      .issue-card::before {
        /* 上端の深緑アクセントライン */
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: var(--color-deep-green);
        border-radius: var(--radius-lg) var(--radius-lg) 0 0;
      }
      .issue-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
      }
      .issue-card__no {
        font-family: var(--font-sans-en);
        font-size: 36px;
        font-weight: 700;
        color: var(--color-accent-gold-dark);
        line-height: 1;
        margin-bottom: var(--space-4);
      }
      .issue-card__tag {
        display: inline-block;
        font-size: 11px;
        letter-spacing: var(--letter-spacing-wider);
        color: var(--color-deep-green);
        background: var(--color-accent-gold);
        padding: 2px 10px;
        border-radius: var(--radius-pill);
        margin-bottom: var(--space-4);
        font-weight: 700;
      }
      .issue-card__title {
        font-size: 19px;
        font-weight: 700;
        color: var(--color-deep-green);
        margin-bottom: var(--space-3);
        line-height: 1.5;
      }
      .issue-card__body {
        font-size: 14px;
        color: var(--color-neutral-80-txt);
        line-height: 1.7;
      }
      .problem__quote {
        margin-top: var(--space-12);
        font-size: 17px;
        color: var(--color-neutral-80-txt);
        font-style: italic;
        padding-left: var(--space-6);
        border-left: 3px solid var(--color-accent-gold);
        max-width: 720px;
      }

      /* ===== Purposes section ===== */
      .purpose-card {
        position: relative;
        background: var(--color-white);
        border-radius: var(--radius-lg);
        padding: var(--space-10) var(--space-8) var(--space-8);
        border: 1px solid var(--color-neutral-30-border);
        text-align: center;
        transition: transform var(--duration-base) var(--ease-out),
          box-shadow var(--duration-base) var(--ease-out),
          border-color var(--duration-base) var(--ease-out);
      }
      .purpose-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-md);
        border-color: var(--color-deep-green);
      }
      .purpose-card__icon {
        width: 88px;
        height: 88px;
        margin: 0 auto var(--space-6);
        color: var(--color-white);
        background: var(--color-deep-green);
        border-radius: 50%;
        padding: 22px;
        box-shadow: 0 0 0 6px rgba(232, 222, 159, 0.5);
      }
      .purpose-card__icon svg {
        width: 100%;
        height: 100%;
      }
      .purpose-card__label-en {
        font-family: var(--font-sans-en);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: var(--letter-spacing-wider);
        color: var(--color-deep-green);
        opacity: 0.6;
        margin-bottom: var(--space-2);
      }
      .purpose-card__title {
        font-size: 22px;
        font-weight: 700;
        color: var(--color-deep-green);
        margin-bottom: var(--space-4);
      }
      .purpose-card__body {
        font-size: 14px;
        color: var(--color-neutral-80-txt);
        line-height: 1.8;
        margin-bottom: var(--space-6);
        text-align: left;
      }
      .purpose-card__deliverable {
        background: var(--color-neutral-10-bg);
        padding: var(--space-4);
        border-radius: var(--radius-md);
        font-size: 12px;
        color: var(--color-deep-green);
        text-align: left;
      }
      .purpose-card__deliverable strong {
        display: block;
        font-size: 11px;
        letter-spacing: var(--letter-spacing-wider);
        opacity: 0.7;
        margin-bottom: var(--space-1);
      }

      /* ===== Approach (5 step timeline) ===== */
      .approach {
        background: var(--color-deep-green-soft);
      }
      .approach__layout {
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        gap: var(--space-12);
        align-items: flex-start;
      }
      @media (max-width: 880px) {
        .approach__layout {
          grid-template-columns: 1fr;
        }
      }
      .approach__photo {
        position: sticky;
        top: 100px;
      }
      .approach__timeline {
        position: relative;
      }
      .approach__step {
        position: relative;
        padding-left: var(--space-16);
        padding-bottom: var(--space-12);
      }
      .approach__step:last-child {
        padding-bottom: 0;
      }
      .approach__step::before {
        content: "";
        position: absolute;
        left: 23px;
        top: 12px;
        bottom: 0;
        width: 2px;
        background: linear-gradient(
          180deg,
          var(--color-accent-gold) 0%,
          var(--color-accent-gold) 50%,
          rgba(232, 222, 159, 0.3) 100%
        );
      }
      .approach__step:last-child::before {
        display: none;
      }
      .approach__step-marker {
        position: absolute;
        left: 0;
        top: 4px;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: var(--color-deep-green);
        color: var(--color-white);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-sans-en);
        font-size: 14px;
        font-weight: 700;
        z-index: 1;
        border: 3px solid var(--color-white);
        box-shadow: 0 0 0 1px var(--color-accent-gold);
      }
      .approach__step--featured .approach__step-marker {
        background: var(--gradient-gold);
        color: var(--color-deep-green);
      }
      .approach__step-label {
        font-family: var(--font-sans-en);
        font-size: 12px;
        letter-spacing: var(--letter-spacing-wider);
        color: var(--color-deep-green);
        opacity: 0.6;
        margin-bottom: var(--space-1);
      }
      .approach__step-title {
        font-size: 22px;
        font-weight: 700;
        color: var(--color-deep-green);
        margin-bottom: var(--space-3);
      }
      .approach__step-body {
        font-size: 15px;
        color: var(--color-neutral-80-txt);
        line-height: 1.8;
      }
      .approach__step-pill {
        display: inline-block;
        margin-left: var(--space-3);
        padding: 2px 10px;
        background: var(--gradient-gold);
        border-radius: var(--radius-pill);
        font-size: 11px;
        font-weight: 700;
        color: var(--color-deep-green);
        letter-spacing: var(--letter-spacing-wider);
      }

      /* ===== Tech Card Showcase ===== */
      .techcard {
        background:
          radial-gradient(
            ellipse at center top,
            rgba(232, 222, 159, 0.15) 0%,
            transparent 60%
          ),
          var(--color-deep-green);
        color: var(--color-white);
      }
      .techcard .section__eyebrow,
      .techcard .section__title {
        color: var(--color-white);
      }
      .techcard .section__eyebrow {
        border-bottom-color: var(--color-accent-gold);
      }
      .techcard .section__lead {
        color: rgba(255, 255, 255, 0.78);
      }
      .techcard__layout {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: var(--space-12);
        align-items: center;
        margin-top: var(--space-8);
      }
      @media (max-width: 880px) {
        .techcard__layout {
          grid-template-columns: 1fr;
        }
      }
      .techcard__sample {
        background: var(--color-white);
        color: var(--color-neutral-100-txt);
        border-radius: var(--radius-lg);
        padding: var(--space-8);
        box-shadow: var(--shadow-lg);
      }
      .techcard__sample-no {
        font-family: var(--font-sans-en);
        font-size: 12px;
        letter-spacing: var(--letter-spacing-wider);
        color: var(--color-deep-green);
        opacity: 0.6;
        margin-bottom: var(--space-2);
      }
      .techcard__sample-title {
        font-size: 24px;
        font-weight: 700;
        color: var(--color-deep-green);
        margin-bottom: var(--space-6);
        line-height: 1.4;
      }
      .techcard__sample-row {
        display: grid;
        grid-template-columns: 36px 1fr;
        gap: var(--space-4);
        padding: var(--space-3) 0;
        border-top: 1px solid var(--color-neutral-30-border);
        align-items: flex-start;
      }
      .techcard__sample-row:first-of-type {
        border-top: 0;
      }
      .techcard__sample-row-icon {
        width: 28px;
        height: 28px;
        color: var(--color-deep-green);
        background: var(--gradient-gold);
        padding: 5px;
        border-radius: var(--radius-md);
      }
      .techcard__sample-row-icon svg {
        width: 100%;
        height: 100%;
      }
      .techcard__sample-row-content {
        font-size: 13.5px;
        line-height: 1.7;
      }
      .techcard__sample-row-content strong {
        display: block;
        font-family: var(--font-sans-en);
        font-size: 11px;
        letter-spacing: var(--letter-spacing-wider);
        color: var(--color-deep-green);
        opacity: 0.7;
        margin-bottom: 2px;
      }

      .techcard__legend {
        display: grid;
        gap: var(--space-4);
      }
      .techcard__legend-item {
        display: grid;
        grid-template-columns: 56px 1fr;
        gap: var(--space-4);
        align-items: center;
        padding: var(--space-4);
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(232, 222, 159, 0.25);
        border-radius: var(--radius-md);
      }
      .techcard__legend-icon {
        width: 56px;
        height: 56px;
        background: var(--gradient-gold);
        border-radius: var(--radius-md);
        padding: 12px;
        color: var(--color-deep-green);
      }
      .techcard__legend-icon svg {
        width: 100%;
        height: 100%;
      }
      .techcard__legend-name {
        font-family: var(--font-sans-en);
        font-size: 12px;
        letter-spacing: var(--letter-spacing-wider);
        color: var(--color-accent-gold);
        margin-bottom: 2px;
      }
      .techcard__legend-jp {
        font-size: 16px;
        font-weight: 700;
        color: var(--color-white);
      }
      .techcard__quote {
        margin-top: var(--space-12);
        text-align: center;
        font-size: 18px;
        color: var(--color-accent-gold);
        font-weight: 500;
      }

      /* ===== Use Cases ===== */
      .usecase-card {
        background: var(--color-white);
        border: 1px solid var(--color-neutral-30-border);
        border-radius: var(--radius-lg);
        padding: 0;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transition: transform var(--duration-base) var(--ease-out),
          box-shadow var(--duration-base) var(--ease-out);
      }
      .usecase-card__photo {
        border-radius: 0 !important;
        border-left: 0 !important;
        border-right: 0 !important;
        border-top: 0 !important;
      }
      .usecase-card__body-wrap {
        padding: var(--space-8);
        display: flex;
        flex-direction: column;
        flex: 1;
      }
      .usecase-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-md);
      }
      .usecase-card__label {
        font-family: var(--font-sans-en);
        font-size: 12px;
        letter-spacing: var(--letter-spacing-wider);
        color: var(--color-deep-green);
        opacity: 0.6;
        margin-bottom: var(--space-2);
      }
      .usecase-card__title {
        font-size: 24px;
        font-weight: 700;
        color: var(--color-deep-green);
        margin-bottom: var(--space-3);
      }
      .usecase-card__industry {
        display: inline-block;
        font-size: 12px;
        background: var(--color-accent-gold);
        color: var(--color-deep-green);
        padding: 2px 12px;
        border-radius: var(--radius-pill);
        margin-bottom: var(--space-6);
        font-weight: 700;
      }
      .usecase-card__body {
        font-size: 15px;
        color: var(--color-neutral-80-txt);
        line-height: 1.8;
        margin-bottom: var(--space-6);
      }
      .usecase-card__quote {
        margin-top: auto;
        padding: var(--space-4);
        background: var(--color-neutral-10-bg);
        border-left: 3px solid var(--color-accent-gold);
        font-size: 14px;
        line-height: 1.7;
        color: var(--color-deep-green);
        font-style: italic;
      }
      .usecase-card__quote-author {
        display: block;
        margin-top: var(--space-2);
        font-size: 12px;
        color: var(--color-neutral-80-txt);
        font-style: normal;
      }

      /* ===== Voices ===== */
      .voices {
        background: var(--color-neutral-10-bg);
      }
      .voices__hero {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: var(--space-12);
        align-items: center;
        margin-bottom: var(--space-12);
      }
      @media (max-width: 720px) {
        .voices__hero {
          grid-template-columns: 1fr;
          gap: var(--space-6);
        }
      }
      .voices__big-number {
        font-family: var(--font-sans-en);
        font-size: 144px;
        font-weight: 700;
        line-height: 0.9;
        color: var(--color-deep-green);
        letter-spacing: -0.03em;
      }
      .voices__big-number sup {
        font-size: 0.4em;
        vertical-align: top;
        margin-left: 4px;
      }
      .voices__big-meta {
        font-size: 17px;
        color: var(--color-neutral-80-txt);
        line-height: 1.7;
      }
      .voices__big-meta strong {
        display: block;
        font-size: 22px;
        color: var(--color-deep-green);
        margin-bottom: var(--space-2);
      }
      .voices__list {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--space-4);
      }
      @media (max-width: 880px) {
        .voices__list {
          grid-template-columns: 1fr;
        }
      }
      .voice {
        background: var(--color-white);
        padding: var(--space-6);
        border-radius: var(--radius-lg);
        border: 1px solid var(--color-neutral-30-border);
      }
      .voice__quote {
        font-size: 14px;
        line-height: 1.8;
        color: var(--color-neutral-100-txt);
        margin-bottom: var(--space-4);
      }
      .voice__author-row {
        display: flex;
        align-items: center;
        gap: var(--space-3);
      }
      .voice__author {
        font-size: 12px;
        color: var(--color-neutral-80-txt);
        line-height: 1.5;
      }

      /* ===== Session Timeline (horizontal) ===== */
      .session-timeline {
        position: relative;
        max-width: 1080px;
        margin: 0 auto;
      }
      .session-timeline__track {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: var(--space-3);
        position: relative;
      }
      .session-timeline__track::before {
        content: "";
        position: absolute;
        top: 24px;
        left: 5%;
        right: 5%;
        height: 2px;
        background: linear-gradient(
          90deg,
          var(--color-accent-gold) 0%,
          var(--color-accent-gold) 100%
        );
      }
      .session-step {
        position: relative;
        text-align: center;
      }
      .session-step__dot {
        width: 48px;
        height: 48px;
        margin: 0 auto var(--space-4);
        border-radius: 50%;
        background: var(--color-white);
        border: 3px solid var(--color-deep-green);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-sans-en);
        font-weight: 700;
        font-size: 14px;
        color: var(--color-deep-green);
        position: relative;
        z-index: 1;
      }
      .session-step__time {
        font-family: var(--font-sans-en);
        font-size: 13px;
        font-weight: 700;
        color: var(--color-deep-green);
        margin-bottom: var(--space-1);
      }
      .session-step__title {
        font-size: 15px;
        font-weight: 700;
        color: var(--color-deep-green);
        margin-bottom: var(--space-2);
        line-height: 1.4;
      }
      .session-step__desc {
        font-size: 12px;
        color: var(--color-neutral-80-txt);
        line-height: 1.6;
      }
      @media (max-width: 720px) {
        .session-timeline__track {
          grid-template-columns: 1fr;
          gap: var(--space-6);
        }
        .session-timeline__track::before {
          left: 24px;
          right: auto;
          top: 24px;
          bottom: 24px;
          width: 2px;
          height: auto;
        }
        .session-step {
          display: grid;
          grid-template-columns: 48px 1fr;
          gap: var(--space-4);
          align-items: flex-start;
          text-align: left;
        }
        .session-step__dot {
          margin: 0;
        }
      }
      .session-timeline__note {
        margin-top: var(--space-12);
        text-align: center;
        font-size: 14px;
        color: var(--color-neutral-80-txt);
      }

      /* ===== Plans ===== */
      .plans {
        background: linear-gradient(
          180deg,
          var(--color-neutral-10-bg) 0%,
          var(--color-white) 100%
        );
      }
      .plan-card {
        position: relative;
        background: var(--color-white);
        border: 1px solid var(--color-neutral-30-border);
        border-radius: var(--radius-lg);
        padding: var(--space-8);
        display: flex;
        flex-direction: column;
        transition: transform var(--duration-base) var(--ease-out),
          box-shadow var(--duration-base) var(--ease-out);
      }
      .plan-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-md);
      }
      .plan-card--featured {
        border: 2px solid var(--color-deep-green);
        box-shadow: var(--shadow-lg);
        background:
          linear-gradient(180deg, rgba(13, 38, 35, 0.04) 0%, transparent 80px),
          var(--color-white);
        padding-top: calc(var(--space-8) + 12px);
      }
      .plan-card--featured::before {
        content: "";
        position: absolute;
        top: 0;
        left: -2px;
        right: -2px;
        height: 8px;
        background: var(--color-deep-green);
        border-radius: var(--radius-lg) var(--radius-lg) 0 0;
      }
      .plan-card__badge {
        position: absolute;
        top: -14px;
        left: 50%;
        transform: translateX(-50%);
        padding: 4px 16px;
        background: var(--color-deep-green);
        color: var(--color-white);
        font-family: var(--font-sans-en);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: var(--letter-spacing-wider);
        border-radius: var(--radius-pill);
      }
      .plan-card__name-en {
        font-family: var(--font-sans-en);
        font-size: 13px;
        letter-spacing: var(--letter-spacing-wider);
        color: var(--color-deep-green);
        opacity: 0.6;
        margin-bottom: var(--space-2);
      }
      .plan-card__name {
        font-size: 22px;
        font-weight: 700;
        color: var(--color-deep-green);
        margin-bottom: var(--space-6);
      }
      .plan-card__price {
        font-family: var(--font-sans-en);
        font-size: 40px;
        font-weight: 700;
        color: var(--color-deep-green);
        line-height: 1;
        margin-bottom: var(--space-2);
      }
      .plan-card__price-unit {
        font-size: 14px;
        font-weight: 400;
        color: var(--color-neutral-80-txt);
      }
      .plan-card__note {
        font-size: 12px;
        color: var(--color-neutral-80-txt);
        margin-bottom: var(--space-6);
      }
      .plan-card__features {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
        margin-bottom: var(--space-8);
      }
      .plan-card__feature {
        display: grid;
        grid-template-columns: 16px 1fr;
        gap: var(--space-3);
        font-size: 14px;
        color: var(--color-neutral-80-txt);
        line-height: 1.6;
      }
      .plan-card__feature svg {
        width: 16px;
        height: 16px;
        color: var(--color-deep-green);
        margin-top: 2px;
        flex-shrink: 0;
      }
      .plan-card .btn {
        width: 100%;
        justify-content: center;
      }

      /* ===== CTA Block（consulting/training 統一仕様）=====
         大きめクリッカブルカード × 2、背景画像 + ホバーで浮く。
         HubSpotリンクは cynthialy 標準（資料請求 + 無料相談）。 */
      .cta-block {
        background:
          radial-gradient(
            ellipse at top right,
            rgba(232, 222, 159, 0.12) 0%,
            transparent 60%
          ),
          var(--color-deep-green);
        color: var(--color-white);
      }
      .cta-block .section__eyebrow {
        color: var(--color-accent-gold);
        border-bottom-color: var(--color-accent-gold);
      }
      .cta-block .section__title {
        color: var(--color-white);
      }
      .cta-block .section__lead {
        color: rgba(255, 255, 255, 0.85);
      }
      .cta-block__h2-pair {
        display: inline-block;
      }
      .cta-block__grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-6);
        margin-top: var(--space-12);
        list-style: none;
        padding: 0;
      }
      @media (max-width: 720px) {
        .cta-block__grid {
          grid-template-columns: 1fr;
        }
      }
      .cta-card {
        position: relative;
        display: block;
        border-radius: var(--radius-lg);
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        background: var(--color-white);
        box-shadow: var(--shadow-md);
        transition: transform var(--duration-base) var(--ease-out),
          box-shadow var(--duration-base) var(--ease-out);
        min-height: 220px;
      }
      .cta-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
      }
      .cta-card__media {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        z-index: 0;
      }
      .cta-card__media::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          135deg,
          rgba(13, 38, 35, 0.85) 0%,
          rgba(13, 38, 35, 0.55) 70%,
          rgba(13, 38, 35, 0.35) 100%
        );
      }
      .cta-card__body {
        position: relative;
        z-index: 1;
        padding: var(--space-10);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
        min-height: 220px;
      }
      .cta-card__title {
        font-size: 24px;
        font-weight: 700;
        color: var(--color-white);
        line-height: 1.4;
        letter-spacing: var(--letter-spacing-tight);
      }
      .cta-card__title small {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.75);
        margin-bottom: var(--space-2);
      }
      .cta-card__pill {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        padding: 10px 20px;
        background: var(--color-accent-gold);
        color: var(--color-deep-green);
        border-radius: var(--radius-pill);
        font-weight: 700;
        font-size: 14px;
        align-self: flex-start;
        margin-top: var(--space-6);
        transition: background var(--duration-base) var(--ease-out),
          gap var(--duration-base) var(--ease-out);
      }
      .cta-card:hover .cta-card__pill {
        background: var(--color-white);
        gap: var(--space-3);
      }
      .cta-card__pill svg {
        width: 14px;
        height: 14px;
        stroke: currentColor;
        stroke-width: 2;
        fill: none;
      }

      /* ===== Footer ===== */
      .site-footer {
        background: #061513;
        color: rgba(255, 255, 255, 0.6);
        padding: var(--space-12) var(--space-6);
        font-size: 13px;
      }
      .site-footer__inner {
        max-width: 1280px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: var(--space-4);
      }
      .site-footer a:hover {
        color: var(--color-accent-gold);
      }

      /* ===== Photo placeholder + 実画像差し替え対応 =====
         画像ファイル（npm run generate:images で生成）が存在すれば img.photo__src が画像を覆い、
         無ければプレースホルダ（ストライプ + 被写体メモ）が透けて見える。 */
      .photo {
        position: relative;
        background:
          linear-gradient(
            135deg,
            var(--color-deep-green-08) 0%,
            rgba(232, 222, 159, 0.12) 100%
          ),
          repeating-linear-gradient(
            45deg,
            transparent 0 14px,
            rgba(13, 38, 35, 0.04) 14px 15px
          );
        border: 1px dashed rgba(13, 38, 35, 0.2);
        border-radius: var(--radius-lg);
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-deep-green);
      }
      .photo__src {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 1;
      }
      /* 画像が読み込めた時は枠と内部マークを隠す。
         404 のとき onerror="this.remove()" で <img> 自体を消す → 自動的にプレースホルダ復活。 */
      .photo:has(.photo__src) {
        border-color: transparent;
        background: var(--color-neutral-10-bg);
      }
      .photo:has(.photo__src) .photo__camera,
      .photo:has(.photo__src) .photo__label {
        display: none;
      }
      .photo--16x10 { aspect-ratio: 16 / 10; }
      .photo--3x2 { aspect-ratio: 3 / 2; }
      .photo--1x1 { aspect-ratio: 1 / 1; }
      .photo--full { width: 100%; }
      .photo__camera {
        width: 36px;
        height: 36px;
        opacity: 0.35;
        position: absolute;
        top: var(--space-4);
        right: var(--space-4);
      }
      .photo__label {
        position: absolute;
        bottom: var(--space-3);
        left: var(--space-3);
        right: var(--space-3);
        background: rgba(13, 38, 35, 0.92);
        color: var(--color-white);
        font-size: 11px;
        line-height: 1.5;
        padding: 8px 12px;
        border-radius: var(--radius-sm);
        font-weight: 500;
        display: flex;
        align-items: flex-start;
        gap: var(--space-2);
      }
      .photo__label::before {
        content: "PHOTO";
        font-family: var(--font-sans-en);
        font-weight: 700;
        font-size: 10px;
        letter-spacing: var(--letter-spacing-wider);
        color: var(--color-accent-gold);
        flex-shrink: 0;
      }

      /* ===== Avatar placeholder（声・人物用） ===== */
      .avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(
          135deg,
          var(--color-deep-green) 0%,
          var(--color-deep-green-12) 100%
        );
        color: var(--color-accent-gold);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        position: relative;
        overflow: hidden;
      }
      .avatar svg {
        width: 22px;
        height: 22px;
      }

      /* ===== TRUSTED BY 帯（Hero 直下） ===== */
      .trusted {
        background: var(--color-deep-green);
        color: var(--color-white);
        padding: var(--space-8) var(--space-6);
      }
      .trusted__inner {
        max-width: 1180px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: auto 1fr;
        gap: var(--space-12);
        align-items: center;
      }
      @media (max-width: 720px) {
        .trusted__inner {
          grid-template-columns: 1fr;
          gap: var(--space-4);
        }
      }
      .trusted__label {
        font-family: var(--font-sans-en);
        font-size: 12px;
        letter-spacing: var(--letter-spacing-wider);
        font-weight: 700;
        color: var(--color-accent-gold);
      }
      .trusted__industries {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-3) var(--space-6);
        font-size: 14px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.85);
      }
      .trusted__industries span {
        position: relative;
      }
      .trusted__industries span:not(:last-child)::after {
        content: "/";
        position: absolute;
        right: -16px;
        color: var(--color-accent-gold);
        opacity: 0.4;
      }

      /* ===== Hidden SVG sprite ===== */
      .icon-sprite {
        position: absolute;
        width: 0;
        height: 0;
        overflow: hidden;
      }
    </style>
  </head>

