---
/**
 * /case/[slug] 動的ルート
 * ---------------------------------------------------------------
 * 2 系統のレンダリングを切り替える:
 *
 * 1. **ミラー準拠 HTML テンプレート** (pixel-match、本番 cynthialy.co.jp/case/* と同一デザイン)
 *    - 対象: frontmatter の mirrorTemplate が "case" のエントリ
 *    - 仕組: ミラーの完全 SSR HTML を読み込み、{{COMPANY}} 等のトークンを
 *            frontmatter から substitute してレンダリング
 *    - メリット: CSS ハッシュ・フォント・アニメ含めて本番と見分けつかない
 *
 * 2. **Astro CaseLayout + MDX** (テンプレート未採用のエントリ向け)
 *    - 対象: mirrorTemplate が未設定のエントリ
 *    - 仕組: CaseLayout に <Content /> (MDX 本文) をスロット
 *    - メリット: 記事本文を Markdown で書ける、CMS 連携が容易
 *
 * 新規の CMS 記事を追加するときは、ひな形に沿った frontmatter と
 * MDX 本文を `src/content/works/{slug}.mdx` に追加するだけで OK。
 */
import { getCollection, type CollectionEntry } from "astro:content";
import CaseLayout from "../../layouts/CaseLayout.astro";

// Vite の `?raw` インポートでビルド時に HTML テンプレ／CSS を文字列展開
import caseTemplateBody from "../../assets/case-template-body.html?raw";
import caseTemplateHeadStyles from "../../assets/case-template-head-styles.html?raw";

export async function getStaticPaths() {
  const entries = await getCollection("works");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"works">;
}

const { entry } = Astro.props;

/** ミラー準拠テンプレートで描画するか判定 */
const useMirrorTemplate =
  (entry.data as any).mirrorTemplate === "case" ||
  // デフォルト挙動: 本家から移設済みの既存エントリはテンプレ描画
  entry.slug === "X8Q6V52T";

function renderMirrorHtml(
  tpl: string,
  e: CollectionEntry<"works">,
): string {
  const d = e.data;
  const fmt = (dt: Date) => `${dt.getFullYear()}/${dt.getMonth() + 1}/${dt.getDate()}`;
  const iso = (dt: Date) => dt.toISOString().slice(0, 10);

  const map: Record<string, string> = {
    COMPANY: d.company ?? "",
    DATE: d.publishedAt ? fmt(d.publishedAt) : "",
    DATE_ISO: d.publishedAt ? iso(d.publishedAt) : "",
    BEFORE_1: d.before?.[0] ?? "",
    BEFORE_2: d.before?.[1] ?? "",
    BEFORE_3: d.before?.[2] ?? "",
    AFTER_1: d.after?.[0] ?? "",
    AFTER_2: d.after?.[1] ?? "",
    AFTER_3: d.after?.[2] ?? "",
    SUMMARY_1: d.summary ?? "",
    SUMMARY_2: "",
    SUMMARY_3: "",
    TOC_1: d.toc?.[0] ?? "",
    TOC_2: d.toc?.[1] ?? "",
    TOC_3: d.toc?.[2] ?? "",
    TOC_4: d.toc?.[3] ?? "",
    TOC_5: d.toc?.[4] ?? "",
  };

  let out = tpl;
  for (const [k, v] of Object.entries(map)) {
    const re = new RegExp(`\\{\\{${k}\\}\\}`, "g");
    out = out.replace(re, String(v));
  }
  return out;
}

// ---- レンダリング分岐 ----
let mirrorHtml: string | null = null;
let mdxContent: any = null;

if (useMirrorTemplate) {
  mirrorHtml = renderMirrorHtml(caseTemplateBody, entry);
} else {
  const { Content } = await entry.render();
  mdxContent = Content;
}

const canonical = `https://cynthialy.co.jp/case/${entry.slug}`;
const pageTitle = `${entry.data.title} | 導入事例 | シンシアリー株式会社`;
const pageDescription = entry.data.summary.slice(0, 120);
---

{
  useMirrorTemplate ? (
    <html lang="ja">
      <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{pageTitle}</title>
        <meta name="description" content={pageDescription} />
        <link rel="canonical" href={canonical} />

        {/* Studio/Nuxt CSS バンドル */}
        <link rel="stylesheet" href="/_nuxt/entry.C0E92ihM.css" crossorigin="" />
        {/* Google Fonts */}
        <link
          href="https://fonts.googleapis.com/css?display=swap&family=Poppins:wght@400"
          rel="stylesheet"
        />
        <link
          href="https://fonts.googleapis.com/css?display=swap&family=Lato:wght@700"
          rel="stylesheet"
        />
        <link
          href="https://fonts.googleapis.com/css?display=swap&family=Inter:wght@500"
          rel="stylesheet"
        />

        {/* head 内のクリティカル <style> */}
        <Fragment set:html={caseTemplateHeadStyles} />
      </head>

      <body>
        <Fragment set:html={mirrorHtml} />

        {/* cynthialy ランタイム (loop-box/video/appear) */}
        <script is:inline src="/_astro/cynthialy-runtime.js" />
      </body>
    </html>
  ) : (
    <CaseLayout slug={entry.slug} frontmatter={entry.data}>
      <mdxContent />
    </CaseLayout>
  )
}
