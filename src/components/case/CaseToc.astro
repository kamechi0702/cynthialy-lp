---
/**
 * CaseToc.astro
 * ---------------------------------------------------------------
 * 事例記事の目次。
 * 本家 /case/X8Q6V52T では「目次」ラベル + 番号付きリスト で
 * H2 へのアンカーリンクを列挙している。番号は "01" "02" ... と
 * ゼロパディングし、タイトル部分と縦棒で区切るデザイン。
 *
 * アンカー ID は日本語 slugify の不安定性を避けるため
 * "sec-01" "sec-02" ... のインデックス ID を採用する。
 * MDX 側は `<h2 id="sec-01">…</h2>` の形で書く運用。
 */
interface Props {
  items: string[];
}

const { items } = Astro.props;

const pad2 = (n: number) => String(n).padStart(2, "0");
const anchorId = (i: number) => `sec-${pad2(i + 1)}`;
---

<nav class="case-toc" aria-label="目次">
  <div class="case-toc__inner">
    <p class="case-toc__label">目次</p>
    <ol class="case-toc__list">
      {
        items.map((t, i) => (
          <li class="case-toc__item">
            <a href={`#${anchorId(i)}`} class="case-toc__link">
              <span class="case-toc__num">{pad2(i + 1)}</span>
              <span class="case-toc__sep" aria-hidden="true" />
              <span class="case-toc__text">{t}</span>
            </a>
          </li>
        ))
      }
    </ol>
  </div>
</nav>

<style>
  .case-toc {
    padding: 32px 16px;
    background: #fff;
  }
  .case-toc__inner {
    max-width: 800px;
    margin-inline: auto;
    padding: 28px 28px 28px;
    border: 1px solid var(--color-neutral-30-border);
    border-radius: var(--radius-md);
    background: #fafaf5;
  }
  .case-toc__label {
    margin: 0 0 16px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-sans-en);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-deep-green);
  }
  .case-toc__label::before {
    content: "";
    width: 24px;
    height: 2px;
    background: var(--color-accent-gold);
    display: inline-block;
  }
  .case-toc__list {
    margin: 0;
    padding: 0;
    list-style: none;
    counter-reset: toc;
  }
  .case-toc__item + .case-toc__item {
    border-top: 1px dashed var(--color-neutral-30-border);
  }
  .case-toc__link {
    display: grid;
    grid-template-columns: auto 1px 1fr;
    align-items: center;
    gap: 14px;
    padding: 12px 4px;
    color: var(--color-neutral-100-txt);
    text-decoration: none;
    font-size: 15px;
    line-height: 1.7;
    transition: color var(--duration-base) var(--ease-out);
  }
  .case-toc__link:hover {
    color: var(--color-deep-green);
  }
  .case-toc__num {
    font-family: var(--font-sans-en);
    font-size: 18px;
    font-weight: 600;
    color: var(--color-accent-gold-dark);
    min-width: 28px;
    letter-spacing: 0.02em;
  }
  .case-toc__sep {
    width: 1px;
    align-self: stretch;
    background: var(--color-neutral-30-border);
  }
  .case-toc__text {
    font-weight: 500;
  }
  @media (max-width: 540px) {
    .case-toc__inner {
      padding: 22px 20px;
    }
    .case-toc__link {
      padding: 10px 2px;
      font-size: 14px;
      gap: 10px;
    }
    .case-toc__num {
      font-size: 16px;
      min-width: 24px;
    }
  }
</style>
