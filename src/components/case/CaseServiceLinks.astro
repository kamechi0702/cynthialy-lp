---
/**
 * CaseServiceLinks.astro
 * ---------------------------------------------------------------
 * 事例記事の末尾に固定配置する「関連サービス」ブロック。
 * 本家 cynthialy.co.jp の事例ページでは、この位置から
 *   - 生成AI研修 ( /services#training )
 *   - 生成AIコンサルティング ( /services#consulting )
 * へ導線を張っている。
 *
 * シンシアリーの2本柱サービスを並べるので、数量は固定(2)。
 * 将来 3本目が増えたら props 化するのがよい。
 */
const services = [
  {
    eyebrow: "SERVICE 01",
    title: "生成AI研修",
    lead: "全社員の生成AIリテラシーを底上げ。部署別カリキュラムと実務課題への適用を組み合わせ、導入直後から成果が出る状態まで伴走します。",
    href: "/services#training",
    tag: "研修",
  },
  {
    eyebrow: "SERVICE 02",
    title: "生成AIコンサルティング",
    lead: "業務プロセスの棚卸しから、生成AIで置き換えるべきタスクの特定、PoC、運用設計までを一気通貫で支援。経営課題に直結する投資対効果を設計します。",
    href: "/services#consulting",
    tag: "コンサル",
  },
];
---

<section class="case-services" aria-labelledby="case-services-title">
  <div class="case-services__inner">
    <div class="case-services__head">
      <p class="case-services__eyebrow">RELATED SERVICES</p>
      <h2 id="case-services-title" class="case-services__title">
        この事例に関連するサービス
      </h2>
    </div>

    <ul class="case-services__list">
      {
        services.map((s) => (
          <li class="case-services__item">
            <a href={s.href} class="case-services__link">
              <div class="case-services__tag">{s.tag}</div>
              <div class="case-services__body">
                <p class="case-services__num">{s.eyebrow}</p>
                <h3 class="case-services__heading">{s.title}</h3>
                <p class="case-services__lead">{s.lead}</p>
              </div>
              <div class="case-services__arrow" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                  <circle cx="14" cy="14" r="13.5" stroke="currentColor" />
                  <path
                    d="M11 9l6 5-6 5"
                    stroke="currentColor"
                    stroke-width="1.4"
                    fill="none"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .case-services {
    padding: 56px 16px 80px;
    background: #fff;
  }
  .case-services__inner {
    max-width: 960px;
    margin-inline: auto;
  }
  .case-services__head {
    text-align: center;
    margin-bottom: 32px;
  }
  .case-services__eyebrow {
    margin: 0 0 8px;
    font-family: var(--font-sans-en);
    font-size: 12px;
    letter-spacing: 0.2em;
    color: var(--color-accent-gold-dark);
    font-weight: 700;
  }
  .case-services__title {
    margin: 0;
    font-size: 22px;
    font-weight: 600;
    color: var(--color-deep-green);
    letter-spacing: 0.04em;
  }
  .case-services__list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  @media (max-width: 720px) {
    .case-services__list {
      grid-template-columns: 1fr;
    }
  }

  .case-services__item {
    position: relative;
  }
  .case-services__link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 16px;
    align-items: center;
    padding: 24px 24px;
    border: 1px solid var(--color-neutral-30-border);
    border-radius: var(--radius-md);
    background: #fff;
    color: inherit;
    text-decoration: none;
    transition:
      border-color var(--duration-base) var(--ease-out),
      box-shadow var(--duration-base) var(--ease-out),
      transform var(--duration-base) var(--ease-out);
  }
  .case-services__link:hover {
    border-color: var(--color-deep-green);
    box-shadow: 0 8px 24px rgba(14, 38, 35, 0.08);
    transform: translateY(-2px);
  }
  .case-services__tag {
    padding: 6px 10px;
    border-radius: var(--radius-sm);
    background: var(--color-accent-gold);
    color: var(--color-deep-green);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    align-self: start;
  }
  .case-services__body {
    min-width: 0;
  }
  .case-services__num {
    margin: 0 0 4px;
    font-family: var(--font-sans-en);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--color-accent-gold-dark);
    font-weight: 700;
  }
  .case-services__heading {
    margin: 0 0 6px;
    font-size: 17px;
    font-weight: 700;
    color: var(--color-deep-green);
  }
  .case-services__lead {
    margin: 0;
    font-size: 13px;
    line-height: 1.75;
    color: var(--color-neutral-80-txt);
  }
  .case-services__arrow {
    color: var(--color-deep-green);
    opacity: 0.6;
    transition: opacity var(--duration-base) var(--ease-out),
      transform var(--duration-base) var(--ease-out);
  }
  .case-services__link:hover .case-services__arrow {
    opacity: 1;
    transform: translateX(4px);
  }
</style>
