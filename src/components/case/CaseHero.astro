---
/**
 * CaseHero.astro
 * ---------------------------------------------------------------
 * 事例記事の冒頭ブロック。
 * 本家 /case/X8Q6V52T では以下の順に積む：
 *   1) H1（会社名）   30px / 秀英角ゴシック銀 M
 *   2) CATEGORY : インタビュー / 日付
 *   3) タグ（#生成AI #事例）
 *   4) Hero 写真（1200x675 → 表示は 800x450）
 *   5) 導入前／導入後 の 2 カラム対比ブロック
 *   6) summary（リード文）
 */
interface Props {
  frontmatter: {
    title: string;
    company: string;
    category: string;
    publishedAt: Date;
    tags: string[];
    heroImage?: string;
    heroImageAlt?: string;
    summary: string;
    before?: string[];
    after?: string[];
  };
}

const { frontmatter } = Astro.props;

const fmtDate = (d: Date) => {
  const y = d.getFullYear();
  const m = d.getMonth() + 1;
  const day = d.getDate();
  return `${y}/${m}/${day}`;
};

const hasMetrics =
  (frontmatter.before?.length ?? 0) > 0 || (frontmatter.after?.length ?? 0) > 0;
---

<section class="case-hero">
  <div class="case-hero__inner">
    <!-- タイトル -->
    <h1 class="case-hero__title">{frontmatter.title}</h1>

    <!-- メタ情報 -->
    <div class="case-hero__meta">
      <span class="case-hero__meta-label">CATEGORY :</span>
      <span class="case-hero__meta-cat">{frontmatter.category}</span>
      <time datetime={frontmatter.publishedAt.toISOString().slice(0, 10)}>
        {fmtDate(frontmatter.publishedAt)}
      </time>
    </div>

    <!-- タグ -->
    {
      frontmatter.tags.length > 0 && (
        <ul class="case-hero__tags">
          {frontmatter.tags.map((t) => (
            <li>
              <a href={`/cases?tag=${encodeURIComponent(t)}`}>#{t}</a>
            </li>
          ))}
        </ul>
      )
    }

    <!-- Hero 写真（未設定時は CASE プレースホルダー） -->
    <figure class="case-hero__figure">
      {
        frontmatter.heroImage ? (
          <img
            src={frontmatter.heroImage}
            alt={frontmatter.heroImageAlt ?? `${frontmatter.company}のインタビュー`}
            width="800"
            height="450"
            loading="eager"
            decoding="async"
          />
        ) : (
          <div class="case-hero__figure-placeholder" aria-hidden="true">
            <span>CASE</span>
          </div>
        )
      }
    </figure>

    <!-- 導入前 / 導入後 の対比ブロック -->
    {
      hasMetrics && (
        <div class="case-hero__metrics">
          <div class="case-hero__metrics-col case-hero__metrics-col--before">
            <p class="case-hero__metrics-label">導入前</p>
            <ul>
              {(frontmatter.before ?? []).map((t) => (
                <li>{t}</li>
              ))}
            </ul>
          </div>
          <div class="case-hero__metrics-arrow" aria-hidden="true">→</div>
          <div class="case-hero__metrics-col case-hero__metrics-col--after">
            <p class="case-hero__metrics-label">導入後</p>
            <ul>
              {(frontmatter.after ?? []).map((t) => (
                <li>{t}</li>
              ))}
            </ul>
          </div>
        </div>
      )
    }

    <!-- リード文 -->
    {frontmatter.summary && <p class="case-hero__summary">{frontmatter.summary}</p>}
  </div>
</section>

<style>
  .case-hero {
    padding: 64px 16px 48px;
    background: #fff;
  }
  .case-hero__inner {
    max-width: 800px;
    margin-inline: auto;
  }
  .case-hero__title {
    margin: 0;
    font-family:
      "秀英角ゴシック銀 M JIS2004",
      var(--font-sans-jp);
    font-size: 30px;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-deep-green-90);
    letter-spacing: 0.01em;
  }
  @media (max-width: 540px) {
    .case-hero {
      padding: 40px 16px 32px;
    }
    .case-hero__title {
      font-size: 22px;
    }
  }

  .case-hero__meta {
    margin-top: 20px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    font-size: 13px;
    color: var(--color-neutral-80-txt);
  }
  .case-hero__meta-label {
    font-family: var(--font-sans-en);
    letter-spacing: 0.08em;
    color: var(--color-deep-green);
    font-weight: 600;
  }
  .case-hero__meta-cat {
    padding: 4px 12px;
    border: 1px solid var(--color-deep-green);
    border-radius: 999px;
    font-size: 12px;
    color: var(--color-deep-green);
    font-weight: 600;
  }

  .case-hero__tags {
    margin: 12px 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 13px;
  }
  .case-hero__tags a {
    color: var(--color-deep-green);
    text-decoration: none;
    padding: 2px 8px;
    background: rgba(232, 222, 159, 0.35);
    border-radius: 4px;
    transition: background var(--duration-base) var(--ease-out);
  }
  .case-hero__tags a:hover {
    background: rgba(232, 222, 159, 0.65);
  }

  .case-hero__figure {
    margin: 36px 0 0;
  }
  .case-hero__figure img {
    width: 100%;
    height: auto;
    max-width: 800px;
    border-radius: 8px;
    object-fit: cover;
    aspect-ratio: 16 / 9;
    display: block;
  }
  .case-hero__figure-placeholder {
    width: 100%;
    max-width: 800px;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--color-deep-green), #1d4524);
    color: rgba(255, 255, 255, 0.75);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans-en);
    letter-spacing: 0.2em;
    font-size: 18px;
  }

  /* ---- Before / After 対比ブロック ---- */
  .case-hero__metrics {
    margin-top: 40px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 12px;
    align-items: stretch;
  }
  @media (max-width: 540px) {
    .case-hero__metrics {
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .case-hero__metrics-arrow {
      transform: rotate(90deg);
      justify-self: center;
    }
  }
  .case-hero__metrics-col {
    padding: 20px 20px 22px;
    border-radius: 12px;
    position: relative;
  }
  .case-hero__metrics-col--before {
    background: #f3f3f3;
    color: #4a4a4a;
  }
  .case-hero__metrics-col--after {
    background: linear-gradient(135deg, #eef5e8 0%, #f6f1cf 100%);
    color: var(--color-deep-green);
  }
  .case-hero__metrics-label {
    margin: 0 0 10px;
    padding: 4px 16px;
    display: inline-block;
    font-family: var(--font-sans-en);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    border-radius: 999px;
    background: #fff;
  }
  .case-hero__metrics-col--before .case-hero__metrics-label {
    color: #6a6a6a;
  }
  .case-hero__metrics-col--after .case-hero__metrics-label {
    color: var(--color-deep-green);
  }
  .case-hero__metrics-col ul {
    margin: 0;
    padding: 0;
    list-style: none;
    font-size: 14px;
    line-height: 1.7;
  }
  .case-hero__metrics-col li {
    position: relative;
    padding-left: 18px;
  }
  .case-hero__metrics-col li + li {
    margin-top: 6px;
  }
  .case-hero__metrics-col li::before {
    content: "●";
    position: absolute;
    left: 0;
    top: 0;
    font-size: 8px;
    line-height: 2.2;
    color: currentColor;
    opacity: 0.5;
  }
  .case-hero__metrics-arrow {
    align-self: center;
    font-size: 28px;
    color: var(--color-accent-gold-dark);
    padding: 0 8px;
  }

  /* ---- リード文 ---- */
  .case-hero__summary {
    margin: 48px 0 0;
    padding: 24px 24px;
    background: rgba(232, 222, 159, 0.2);
    border-left: 3px solid var(--color-accent-gold);
    border-radius: 8px;
    font-size: 15px;
    line-height: 1.95;
    color: var(--color-neutral-100-txt);
  }
</style>
